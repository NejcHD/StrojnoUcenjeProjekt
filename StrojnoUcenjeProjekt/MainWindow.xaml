<Window x:Class="StrojnoUcenjeProjekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klasifikator: k-NN &amp; Odločitveno Drevo" Height="500" Width="850">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#F0F0F0">
            <TextBlock Text="Nastavitve" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <Button x:Name="BtnLoadData" Content=" Naloži CSV Podatke" Click="BtnLoadData_Click" Margin="0,5" Padding="5"/>

            <Separator Margin="0,10"/>

            <TextBlock Text="Izberi algoritem:" FontWeight="SemiBold" Margin="0,5"/>
            <ComboBox x:Name="ComboAlgoritem" Margin="0,5" SelectedIndex="0">
                <ComboBoxItem Content="k-Najbližjih sosedov "/>
                <ComboBoxItem Content="Odločitveno drevo "/>
            </ComboBox>

            <Separator Margin="0,10"/>

            <TextBlock Text="k-NN parameter (k):" Margin="0,5,0,0"/>
            <TextBox x:Name="TxtK" Text="3" Margin="0,5" Padding="3"/>

            <TextBlock FontSize="10" Text="*Parameter k se uporablja le pri k-NN algoritmu." Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <Button x:Name="BtnRun" Content="Zaženi Klasifikacijo" Click="BtnRun_Click" 
                    Background="LightGreen" FontWeight="Bold" Margin="0,10,0,5" Padding="10"/>

            <TextBlock x:Name="TxtStatus" Text="Status: Čakam na podatke..." TextWrapping="Wrap" Margin="0,10" Foreground="#333"/>
            <Button Name="BtnSave" Content="Shrani rezultate" Click="BtnSave_Click" Width="120" Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="15,0,0,0">
            <TextBlock Text="Rezultati analize" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" Background="White" CornerRadius="5">
                <StackPanel>
                    <TextBlock x:Name="TxtAccuracy" Text="Točnost: /" FontSize="16" FontWeight="Medium" Margin="0,5"/>
                    <TextBlock x:Name="TxtF1" Text="Povprečni F1: /" FontSize="16" FontWeight="Medium" Margin="0,5"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Dnevnik dogajanja in Metrike:" Margin="0,20,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtLog" Height="280" 
                     FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto" 
                     IsReadOnly="True" 
                     AcceptsReturn="True" 
                     Background="#FAFAFA" Padding="5"/>
        </StackPanel>
    </Grid>
</Window>